---
interface Props {
  titleZh: string;
  titleEn: string;
  descriptionZh: string;
  descriptionEn: string;
  icon: string;
}

const { titleZh, titleEn, descriptionZh, descriptionEn, icon } = Astro.props;
---

<div class="rounded-2xl p-6 border border-gray-200 bg-white/90 dark:border-gray-700 dark:bg-gray-900/70">
  <h3 class="mb-3 font-semibold text-gray-900 dark:text-gray-100">
    <span data-lang="zh">{icon} {titleZh}</span>
    <span data-lang="en">{icon} {titleEn}</span>
  </h3>
  <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-300">
    <span data-lang="zh">{descriptionZh}</span>
    <span data-lang="en">{descriptionEn}</span>
  </p>
</div>
