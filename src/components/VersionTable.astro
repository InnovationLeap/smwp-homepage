---
/**
 * VersionTable Component
 *
 * 基于 smwp-versions.yaml 文件动态渲染版本历史表格
 *
 * 功能：
 * - 动态加载 YAML 数据源
 * - 版本类型筛选（正式版/测试版）
 * - 版本号倒序排列
 * - 数据包列硬编码逻辑
 * - 错误处理和优雅降级
 */

import { readFileSync } from 'fs';
import { join } from 'path';
import * as yaml from 'js-yaml';

interface VersionInfo {
  version: string;
  date: string;
  zipName: string;
  verCode?: number;
  type: 'release' | 'pre_release';
}

interface Props {
  initialFilter?: 'all' | 'release' | 'pre_release';
}

const { initialFilter = 'all' } = Astro.props;

// 读取并解析 YAML 文件
let versions: VersionInfo[] = [];
let loadError = false;
let errorMessage = '';

try {
  const yamlPath = join(process.cwd(), 'src/data/smwp-versions.yaml');
  const yamlContent = readFileSync(yamlPath, 'utf-8');
  const data = yaml.load(yamlContent) as {
    release?: Array<{ [key: string]: Array<{ date?: string; zip_name?: string; ver_code?: number }> }>;
    pre_release?: Array<{ [key: string]: Array<{ date?: string; zip_name?: string; ver_code?: number }> }>;
  };

  // 解析正式版
  if (data.release) {
    data.release.forEach((item) => {
      const versionKey = Object.keys(item)[0];
      const versionDataArray = item[versionKey];

      // 遍历数组，收集所有字段
      let date = '';
      let zipName = '';
      let verCode: number | undefined;

      if (Array.isArray(versionDataArray)) {
        versionDataArray.forEach((dataItem: any) => {
          if (dataItem.date) date = dataItem.date;
          if (dataItem.zip_name) zipName = dataItem.zip_name;
          if (dataItem.ver_code) verCode = dataItem.ver_code;
        });
      }

      versions.push({
        version: versionKey,
        date,
        zipName,
        verCode,
        type: 'release'
      });
    });
  }

  // 解析测试版
  if (data.pre_release) {
    data.pre_release.forEach((item) => {
      const versionKey = Object.keys(item)[0];
      const versionDataArray = item[versionKey];

      // 遍历数组，收集所有字段
      let date = '';
      let zipName = '';
      let verCode: number | undefined;

      if (Array.isArray(versionDataArray)) {
        versionDataArray.forEach((dataItem: any) => {
          if (dataItem.date) date = dataItem.date;
          if (dataItem.zip_name) zipName = dataItem.zip_name;
          if (dataItem.ver_code) verCode = dataItem.ver_code;
        });
      }

      versions.push({
        version: versionKey,
        date,
        zipName,
        verCode,
        type: 'pre_release'
      });
    });
  }

} catch (error) {
  loadError = true;
  errorMessage = error instanceof Error ? error.message : 'Unknown error';
  console.error('Failed to load smwp-versions.yaml:', error);
}

/**
 * 根据版本号确定数据包显示内容
 *
 * 规则：
 * - v1.5.0 及更新版本：显示 "下载"（可下载）
 * - v1.4 系列（包含 v1.4.0a 和 v1.4.0b）：显示 "下载"（可下载）
 * - v1.2 至 v1.3 系列：显示 "已自带"
 * - 所有早期版本（v1.2 之前）：显示 "需原版 MW"
 */
function getDataPacketDisplay(version: string): { textZh: string; textEn: string; downloadUrl?: string } {
  // 移除版本号前缀 "v"
  const versionNum = version.replace(/^v/i, '');

  // 提取主版本号 (1.5, 1.4, 1.3 等)
  const mainVersionMatch = versionNum.match(/^(\d+)\.(\d+)/);
  if (!mainVersionMatch) {
    return { textZh: '需原版 MW', textEn: 'Require MW 1.1\'s data' };
  }

  const major = parseInt(mainVersionMatch[1]);
  const minor = parseInt(mainVersionMatch[2]);

  // v1.5.0 及更新版本
  if (major >= 2 || (major === 1 && minor >= 5)) {
    return {
      textZh: '下载',
      textEn: 'Download',
      downloadUrl: 'https://file.marioforever.net/smwp/Data.7z'
    };
  }

  // v1.4 系列（包含 v1.4.0a 和 v1.4.0b）
  if (major === 1 && minor === 4) {
    return {
      textZh: '下载',
      textEn: 'Download',
      downloadUrl: 'https://file.marioforever.net/smwp/Data.zip'
    };
  }

  // v1.2 至 v1.3 系列
  if (major === 1 && (minor === 2 || minor === 3)) {
    return {
      textZh: '已自带',
      textEn: 'Included in game'
    };
  }

  // 所有早期版本（v1.2 之前）
  return {
    textZh: '需原版 MW',
    textEn: 'Require MW 1.1\'s data'
  };
}

/**
 * 获取版本代号显示内容
 * 规则：
 * - v1.1 及以前：显示 "-"
 * - v1.1 之后：显示 verCode（如 1712）
 */
function getVersionCodeDisplay(version: string, verCode?: number): string {
  // 移除版本号前缀 "v"
  const versionNum = version.replace(/^v/i, '');

  // 提取主版本号
  const mainVersionMatch = versionNum.match(/^(\d+)\.(\d+)/);
  if (!mainVersionMatch) {
    return '-';
  }

  const major = parseInt(mainVersionMatch[1]);
  const minor = parseInt(mainVersionMatch[2]);

  // v1.1 及以前版本显示 "-"
  if (major < 1 || (major === 1 && minor <= 1)) {
    return '-';
  }

  // v1.1 之后显示版本代号
  return verCode ? verCode.toString() : '-';
}

/**
 * 解析版本号用于排序
 * 支持格式：v1.7.12.1, v1.7.11a, v1.7.11-beta1 等
 */
function parseVersionForSort(version: string): number[] {
  // 移除版本号前缀 "v"
  let v = version.replace(/^v/i, '');

  // 提取数字部分和后缀部分
  const parts: number[] = [];

  // 匹配主要版本号（如 1.7.12.1）
  const mainMatch = v.match(/^(\d+(?:\.\d+)*)/);
  if (mainMatch) {
    const nums = mainMatch[1].split('.').map(n => parseInt(n, 10));
    parts.push(...nums);
  }

  // 处理后缀（如 a, b, beta1, alpha 等）
  const suffixMatch = v.match(/[\d\.]+(.+)$/);
  if (suffixMatch) {
    const suffix = suffixMatch[1];

    // 检测后缀类型并赋予排序权重
    if (suffix.startsWith('beta')) {
      parts.push(-1000); // beta 版排在正式版之前
      const betaNum = suffix.match(/\d+/);
      if (betaNum) {
        parts.push(parseInt(betaNum[0], 10));
      }
    } else if (suffix.startsWith('alpha')) {
      parts.push(-2000); // alpha 版排在 beta 之前
    } else if (suffix.startsWith('Fix')) {
      parts.push(50); // Fix 版排在正式版之后
      const fixNum = suffix.match(/\d+/);
      if (fixNum) {
        parts.push(parseInt(fixNum[0], 10));
      }
    } else if (suffix === 'a' || suffix.startsWith('_a')) {
      parts.push(1);
    } else if (suffix === 'b' || suffix.startsWith('_b')) {
      parts.push(2);
    } else if (suffix.match(/^f\d*$/)) {
      parts.push(60); // f 版（final）排在 Fix 之后
      const fNum = suffix.match(/\d+/);
      if (fNum) {
        parts.push(parseInt(fNum[0], 10));
      }
    } else if (suffix.includes('_')) {
      // 处理其他下划线后缀（如 _Fix1, _Fix2）
      parts.push(10);
    } else {
      parts.push(0);
    }
  }

  // 确保数组长度一致，方便排序
  while (parts.length < 6) {
    parts.push(0);
  }

  return parts;
}

/**
 * 解析日期用于排序
 * 格式：YYYY-MM-DD
 */
function parseDateForSort(dateStr: string): number {
  if (!dateStr) return 0;
  const parts = dateStr.split('-').map(n => parseInt(n, 10));
  // 返回 YYYYMMDD 格式的数字，便于比较
  return parts.length >= 3
    ? parts[0] * 10000 + parts[1] * 100 + parts[2]
    : 0;
}

/**
 * 解析版本号用于升序排序
 * 简化版本，只比较主要版本号
 */
function parseVersionForAsc(version: string): number[] {
  let v = version.replace(/^v/i, '');
  const mainMatch = v.match(/^(\d+(?:\.\d+)*)/);
  if (!mainMatch) return [0];

  return mainMatch[1].split('.').map(n => parseInt(n, 10) || 0);
}

// 按发布日期降序排列，同日期时按版本号升序
versions.sort((a, b) => {
  const dateA = parseDateForSort(a.date);
  const dateB = parseDateForSort(b.date);

  // 主排序：按发布日期降序（最新在前）
  if (dateA !== dateB) {
    return dateB - dateA;
  }

  // 次排序：同日期时按版本号升序
  const aVerParts = parseVersionForAsc(a.version);
  const bVerParts = parseVersionForAsc(b.version);

  for (let i = 0; i < Math.max(aVerParts.length, bVerParts.length); i++) {
    const aVal = aVerParts[i] || 0;
    const bVal = bVerParts[i] || 0;
    if (aVal !== bVal) {
      return aVal - bVal; // 升序
    }
  }

  return 0;
});
---

<div class="version-table-container">
  {/* 错误提示 */}
  {loadError && (
    <div class="error-message bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
      <p class="text-red-700 dark:text-red-400" data-lang="zh">
        ⚠️ 加载版本数据失败：{errorMessage}。请刷新页面重试。
      </p>
      <p class="text-red-700 dark:text-red-400" data-lang="en">
        ⚠️ Failed to load version data: {errorMessage}. Please refresh the page.
      </p>
    </div>
  )}

  {/* 筛选器 */}
  <div class="filter-controls">
    <div class="flex flex-wrap gap-3 items-center">
      <span class="text-gray-600 dark:text-gray-400 font-medium text-sm" data-lang="zh">筛选：</span>
      <span class="text-gray-600 dark:text-gray-400 font-medium text-sm" data-lang="en">Filter:</span>

      <button
        class="filter-btn px-3 py-1 rounded border transition-colors text-sm"
        data-filter="all"
        data-active="true"
      >
        <span data-lang="zh">全部</span>
        <span data-lang="en">All</span>
      </button>

      <button
        class="filter-btn px-3 py-1 rounded border transition-colors text-sm"
        data-filter="release"
      >
        <span data-lang="zh">正式版</span>
        <span data-lang="en">Release</span>
      </button>

      <button
        class="filter-btn px-3 py-1 rounded border transition-colors text-sm"
        data-filter="pre_release"
      >
        <span data-lang="zh">测试版</span>
        <span data-lang="en">Pre-release</span>
      </button>
    </div>
  </div>

  {/* 表格容器 */}
  <div class="table-wrapper overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700">
    <table class="version-table w-full text-sm" id="versionTable">
      <thead class="bg-gray-50 dark:bg-gray-800">
        <tr>
          <th class="px-4 py-3 text-left font-semibold">
            <span data-lang="zh">版本号</span>
            <span data-lang="en">Version</span>
          </th>
          <th class="px-4 py-3 text-left font-semibold">
            <span data-lang="zh">版本代号</span>
            <span data-lang="en">Version Code</span>
          </th>
          <th class="px-4 py-3 text-left font-semibold">
            <span data-lang="zh">发布日期</span>
            <span data-lang="en">Release date</span>
          </th>
          <th class="px-4 py-3 text-left font-semibold">
            <span data-lang="zh">游戏本体</span>
            <span data-lang="en">Game</span>
          </th>
          <th class="px-4 py-3 text-left font-semibold">
            <span data-lang="zh">数据包</span>
            <span data-lang="en">Data</span>
          </th>
          <th class="px-4 py-3 text-left font-semibold">
            <span data-lang="zh">类型</span>
            <span data-lang="en">Type</span>
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
        {versions.map((version, index) => {
          const dataPacket = getDataPacketDisplay(version.version);
          const downloadUrl = `https://file.marioforever.net/smwp/${version.zipName}`;
          const versionCodeDisplay = getVersionCodeDisplay(version.version, version.verCode);

          return (
            <tr
              class="version-row hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors"
              data-type={version.type}
              data-index={index}
            >
              <td class="px-4 py-3 font-medium">
                <span class="version-number">{version.version}</span>
              </td>
              <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
                <code class="version-code">{versionCodeDisplay}</code>
              </td>
              <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
                <span>{version.date}</span>
              </td>
              <td class="px-4 py-3">
                <a
                  href={downloadUrl}
                  class="text-blue-600 dark:text-blue-400 hover:underline font-medium"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span data-lang="zh">下载</span>
                  <span data-lang="en">Download</span>
                </a>
              </td>
              <td class="px-4 py-3">
                {dataPacket.downloadUrl ? (
                  <a
                    href={dataPacket.downloadUrl}
                    class="text-blue-600 dark:text-blue-400 hover:underline font-medium"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span data-lang="zh">{dataPacket.textZh}</span>
                    <span data-lang="en">{dataPacket.textEn}</span>
                  </a>
                ) : (
                  <span class="text-gray-600 dark:text-gray-400">
                    <span data-lang="zh">{dataPacket.textZh}</span>
                    <span data-lang="en">{dataPacket.textEn}</span>
                  </span>
                )}
              </td>
              <td class="px-4 py-3">
                <span class={`type-badge px-2 py-1 rounded text-xs font-medium ${
                  version.type === 'release'
                    ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400'
                    : 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400'
                }`}>
                  <span data-lang="zh">{version.type === 'release' ? '正式版' : '测试版'}</span>
                  <span data-lang="en">{version.type === 'release' ? 'Release' : 'Pre-release'}</span>
                </span>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  {/* 空状态提示 */}
  <div class="empty-state hidden text-center py-12">
    <p class="text-gray-500 dark:text-gray-400" data-lang="zh">没有找到符合条件的版本</p>
    <p class="text-gray-500 dark:text-gray-400" data-lang="en">No versions found</p>
  </div>
</div>

<style>
  .version-table-container {
    width: 100%;
  }

  .filter-controls {
    margin-bottom: 0;
  }

  .filter-btn {
    border-color: var(--gray-200);
    background: white;
    color: var(--gray-700);
  }

  .filter-btn[data-active="true"] {
    background: var(--primary-color, #3b82f6);
    color: white;
    border-color: var(--primary-color, #3b82f6);
  }

  .table-wrapper {
    margin-top: 1rem;
  }

  .version-table thead th {
    padding-top: 0.375rem;
    padding-bottom: 0.375rem;
  }

  .version-table th,
  .version-table td {
    white-space: nowrap;
    padding-top: 0.375rem;
    padding-bottom: 0.375rem;
  }

  .version-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875em;
    background: var(--gray-50);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    border: 1px solid var(--gray-200);
  }

  html.dark .version-code {
    background: #1f2937;
    border-color: #374151;
  }

  @media (max-width: 768px) {
    .version-table th,
    .version-table td {
      font-size: 0.75rem;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
      padding-top: 0.375rem;
      padding-bottom: 0.375rem;
    }
  }

  /* 深色模式变量 */
  :root {
    --gray-50: #f9fafb;
    --gray-200: #e5e7eb;
    --gray-700: #374151;
    --primary-color: #3b82f6;
  }

  html.dark {
    --gray-50: #1f2937;
    --gray-200: #374151;
    --gray-700: #d1d5db;
  }

  html.dark .filter-btn {
    background: #1f2937;
    color: #d1d5db;
    border-color: #374151;
  }

  html.dark .filter-btn:hover:not([data-active="true"]) {
    background: #111827;
  }
</style>

<script>
  // 筛选功能实现
  class VersionTableFilter {
    private buttons: NodeListOf<HTMLButtonElement>;
    private table: HTMLTableElement;
    private emptyState: HTMLElement;
    private currentFilter: string;

    constructor() {
      this.buttons = document.querySelectorAll('.filter-btn');
      this.table = document.getElementById('versionTable') as HTMLTableElement;
      this.emptyState = document.querySelector('.empty-state') as HTMLElement;
      this.currentFilter = 'all';

      this.init();
    }

    private init(): void {
      this.buttons.forEach(btn => {
        btn.addEventListener('click', () => this.handleFilterClick(btn));
      });

      // 监听语言变化，更新按钮状态
      window.addEventListener('language-change', () => {
        this.updateButtonStates();
      });
    }

    private handleFilterClick(btn: HTMLButtonElement): void {
      const filter = btn.dataset.filter || 'all';

      // 更新按钮状态
      this.buttons.forEach(b => {
        b.dataset.active = 'false';
      });
      btn.dataset.active = 'true';

      // 应用筛选
      this.currentFilter = filter;
      this.applyFilter(filter);
    }

    private applyFilter(filter: string): void {
      const rows = this.table.querySelectorAll('.version-row');
      let visibleCount = 0;

      rows.forEach(row => {
        const type = (row as HTMLElement).dataset.type;
        const shouldShow = filter === 'all' || type === filter;

        if (shouldShow) {
          (row as HTMLElement).style.display = '';
          visibleCount++;
        } else {
          (row as HTMLElement).style.display = 'none';
        }
      });

      // 显示/隐藏空状态
      if (visibleCount === 0) {
        this.emptyState.classList.remove('hidden');
        this.table.closest('.table-wrapper')?.classList.add('hidden');
      } else {
        this.emptyState.classList.add('hidden');
        this.table.closest('.table-wrapper')?.classList.remove('hidden');
      }
    }

    private updateButtonStates(): void {
      // 更新当前活动按钮的视觉状态
      this.buttons.forEach(btn => {
        const isActive = btn.dataset.active === 'true';
        if (isActive) {
          btn.setAttribute('aria-pressed', 'true');
        } else {
          btn.setAttribute('aria-pressed', 'false');
        }
      });
    }
  }

  // 初始化筛选功能
  document.addEventListener('DOMContentLoaded', () => {
    new VersionTableFilter();
  });
</script>
