    .info-panel summary {
      padding: 0.75rem 1rem;
    }

    .info-content {
      padding: 0.75rem 1rem;
    }
  }

  /* ============================================================
     减少动画 (无障碍)
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in,
    .animate-slide-up {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .download-btn::before {
      display: none;
    }

    .download-btn-icon {
      transition: none;
    }
  }
</style>

<script>
  // ============================================================
  // 版本数据类型定义
  // ============================================================
  interface VersionInfo {
    version: string;
    date: string;
    zipName: string;
    verCode?: number;
    type: 'release' | 'pre_release';
    downloadUrl: string;
  }

  interface ChangelogEntry {
    version: string;
    date: string;
    content: string;
  }

  // ============================================================
  // 全局状态
  // ============================================================
  let versionsData: VersionInfo[] = [];
  let changelogEntries: ChangelogEntry[] = [];
  let currentFilter: 'release' | 'pre_release' | null = null;

  // ============================================================
  // OpenList API 配置（参考 mfdownload-next 项目）
  // ============================================================
  const OPENLIST_BASE_URL = 'https://file.marioforever.net';
  const fileInfoCache = new Map<string, { data: any; timestamp: number }>();
  const CACHE_EXPIRY_MS = 5 * 60 * 1000; // 5 minutes

  /**
   * 格式化文件大小（与 mfdownload-next 一致）
   */
  const formatFileSize = (bytes: number | null): string => {
    if (!bytes || bytes === 0) return '';

    const units = [
      { name: 'GB', threshold: 1024 * 1024 * 1024 },
      { name: 'MB', threshold: 1024 * 1024 },
      { name: 'KB', threshold: 1024 },
      { name: 'B', threshold: 1 }
    ];

    for (const unit of units) {
      if (bytes >= unit.threshold) {
        const value = bytes / unit.threshold;
        const decimals = unit.name === 'GB' || unit.name === 'MB' ? 2 : (unit.name === 'KB' ? 1 : 0);
        return `${value.toFixed(decimals)} ${unit.name}`;
      }
    }

    return `${bytes} B`;
  };

  /**
   * 从 URL 提取文件路径（与 mfdownload-next 一致）
   */
  const extractPathFromUrl = (url: string): string | null => {
    if (!url) return null;
    if (!url.includes('file.marioforever.net')) return null;

    try {
      const urlObj = new URL(url);
      return decodeURIComponent(urlObj.pathname);
    } catch {
      return null;
    }
  };

  /**
   * 从 OpenList API 获取文件信息（与 mfdownload-next 一致）
   */
  const getFileInfo = async (path: string): Promise<any | null> => {
    if (!path) return null;

    // 检查缓存
    const cachedInfo = fileInfoCache.get(path);
    if (cachedInfo && Date.now() - cachedInfo.timestamp < CACHE_EXPIRY_MS) {
      return cachedInfo.data;
    }

    try {
      // 使用 POST /api/fs/get 获取文件信息
      const response = await fetch(`${OPENLIST_BASE_URL}/api/fs/get`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ path, password: '' }),
        signal: AbortSignal.timeout(5000) // 5 seconds timeout
      });

      if (!response.ok) return null;

      const data = await response.json();

      if (data && data.code === 200 && data.data) {
        const fileInfo = data.data;

        // 缓存结果
        fileInfoCache.set(path, {
          data: fileInfo,
          timestamp: Date.now()
        });

        return fileInfo;
      }

      return null;
    } catch (e) {
      // 静默失败 - 不阻塞 UI
      console.warn('OpenList API request failed:', e);
      return null;
    }
  };

  /**
   * 从 URL 获取文件大小（字节）
   */
  const getFileSizeFromUrl = async (url: string): Promise<number | null> => {
    const path = extractPathFromUrl(url);
    if (!path) return null;

    const fileInfo = await getFileInfo(path);
    if (fileInfo && fileInfo.size) {
      return fileInfo.size;
    }

    return null;
  };

  /**
   * 获取格式化的文件大小
   */
  const getFormattedFileSize = async (url: string): Promise<string> => {
    const size = await getFileSizeFromUrl(url);
    return formatFileSize(size);
  };

  /**
   * 初始化文件大小显示
   */
  const initFileSizes = async () => {
    const elements = document.querySelectorAll<HTMLDivElement>('.file-size');
    const promises = Array.from(elements).map(async (el) => {
      const fileUrl = el.dataset.fileUrl;
      if (!fileUrl) return;

      const size = await getFormattedFileSize(fileUrl);
      if (size) {
        el.textContent = size;
        el.classList.remove('opacity-0');
        el.classList.add('opacity-100');
      }
    });
    await Promise.all(promises);
  };

  // ============================================================
  // 从 Markdown 提取更新日志
  // ============================================================
  const parseChangelogFromMarkdown = () => {
    const source = document.getElementById('markdownSource');
    if (!source) return;

    const lang = document.documentElement.getAttribute('data-lang') || 'zh';
    const langContainer = source.querySelector(`[data-lang="${lang}"]`);
    if (!langContainer) return;

    const allElements = Array.from(langContainer.children);
    let inChangelogSection = false;
    const entries: ChangelogEntry[] = [];
    let currentEntry: ChangelogEntry | null = null;

    allElements.forEach(el => {
      const elHtml = el as HTMLElement;
      if (elHtml.tagName === 'H2') {
        const text = elHtml.textContent?.trim() || '';
        inChangelogSection = text.includes('更新日志') || text.includes('Changelog');
        return;
      }

      if (!inChangelogSection) return;

      if (elHtml.tagName === 'H3') {
        if (currentEntry) entries.push(currentEntry);
        const text = elHtml.textContent?.trim() || '';
        const match = text.match(/(v[\d.]+[a-z0-9]*)\s*(?:\(([\d-]+)\))?/);
        if (match) {
          currentEntry = { version: match[1], date: match[2] || '', content: '' };
        }
      } else if (currentEntry) {
        currentEntry.content += elHtml.outerHTML;
      }
    });

    if (currentEntry) entries.push(currentEntry);
    changelogEntries = entries;
  };

  // ============================================================
  // 版本号匹配逻辑
  // ============================================================
  const getBaseVersion = (version: string): string => {
    // 移除 v 前缀
    let v = version.replace(/^v/i, '');
    // 提取主版本号 (如 1.7.11)
    const match = v.match(/^(\d+(?:\.\d+)*)/);
    return match ? match[1] : v;
  };

  const findChangelogForVersion = (version: string): ChangelogEntry | null => {
    const baseVersion = getBaseVersion(version);
    // 查找版本号以 baseVersion 开头的更新日志
    return changelogEntries.find(entry => {
      const entryBase = getBaseVersion(entry.version);
      return entryBase === baseVersion;
    }) || null;
  };

  // ============================================================
  // 数据包下载链接逻辑
  // ============================================================
  const getDataPacketInfo = (version: string): { text: string; url?: string } => {
    const versionNum = version.replace(/^v/i, '');
    const mainVersionMatch = versionNum.match(/^(\d+)\.(\d+)/);
    if (!mainVersionMatch) {
      return { text: '-' };
    }

    const major = parseInt(mainVersionMatch[1]);
    const minor = parseInt(mainVersionMatch[2]);

    if (major >= 2 || (major === 1 && minor >= 5)) {
      return { text: 'Data.7z', url: 'https://file.marioforever.net/smwp/Data.7z' };
    }

    if (major === 1 && minor === 4) {
      return { text: 'Data.zip', url: 'https://file.marioforever.net/smwp/Data.zip' };
    }

    if (major === 1 && (minor === 2 || minor === 3)) {
      return { text: '-' };
    }

    return { text: '-' };
  };

  // ============================================================
  // 版本代号显示逻辑
  // ============================================================
  const getVersionCodeDisplay = (version: string, verCode?: number): string => {
    const versionNum = version.replace(/^v/i, '');
    const mainVersionMatch = versionNum.match(/^(\d+)\.(\d+)/);
    if (!mainVersionMatch) return '-';

    const major = parseInt(mainVersionMatch[1]);
    const minor = parseInt(mainVersionMatch[2]);

    if (major < 1 || (major === 1 && minor <= 1)) {
      return '-';
    }

    return verCode ? verCode.toString() : '-';
  };

  // ============================================================
  // 渲染版本表格
  // ============================================================
  const renderVersionTable = (type: 'release' | 'pre_release') => {
    const container = document.getElementById('dynamicVersionTable');
    const section = document.getElementById('versionTableSection');
    const title = document.getElementById('versionTableTitle');

    if (!container || !section) return;

    // 显示表格区域
    section.classList.remove('hidden');

    // 更新标题
    if (title) {
      const lang = document.documentElement.getAttribute('data-lang') || 'zh';
      if (type === 'release') {
        title.innerHTML = lang === 'zh'
          ? '<span data-lang="zh">全部正式版</span>'
          : '<span data-lang="en">All Releases</span>';
      } else {
        title.innerHTML = lang === 'zh'
          ? '<span data-lang="zh">全部测试版</span>'
          : '<span data-lang="en">All Pre-releases</span>';
      }
    }

    // 筛选版本
    const filteredVersions = versionsData.filter(v => v.type === type);

    const lang = document.documentElement.getAttribute('data-lang') || 'zh';

    // 渲染表格
    const tableHtml = `
      <table>
        <thead>
          <tr>
            <th>${lang === 'zh' ? '版本号' : 'Version'}</th>
            <th>${lang === 'zh' ? '版本代号' : 'Code'}</th>
            <th>${lang === 'zh' ? '发布日期' : 'Date'}</th>
            <th>${lang === 'zh' ? '游戏本体' : 'Game'}</th>
            <th>${lang === 'zh' ? '数据包' : 'Data'}</th>
            <th>${lang === 'zh' ? '更新日志' : 'Changelog'}</th>
          </tr>
        </thead>
        <tbody>
          ${filteredVersions.map((v, index) => {
            const changelog = findChangelogForVersion(v.version);
            const dataPacket = getDataPacketInfo(v.version);
            const versionCodeDisplay = getVersionCodeDisplay(v.version, v.verCode);

            return `
              <tr>
                <td class="font-medium">${v.version}</td>
                <td><code class="version-code">${versionCodeDisplay}</code></td>
                <td class="text-gray-600 dark:text-gray-400">${v.date || '-'}</td>
                <td>
                  <a href="${v.downloadUrl}" class="table-btn table-btn-primary" target="_blank" rel="noopener noreferrer">
                    <i class="fas fa-download mr-1"></i>
                    ${lang === 'zh' ? '下载' : 'Download'}
                  </a>
                </td>
                <td>
                  ${dataPacket.url
                    ? `<a href="${dataPacket.url}" class="table-btn table-btn-success" target="_blank" rel="noopener noreferrer"><i class="fas fa-download mr-1"></i>${lang === 'zh' ? '下载' : 'Download'}</a>`
                    : dataPacket.text
                  }
                </td>
                <td>
                  ${changelog
                    ? `<button type="button" class="table-btn table-btn-secondary" data-changelog-index="${changelogEntries.indexOf(changelog)}"><i class="fas fa-file-alt mr-1"></i>${lang === 'zh' ? '查看' : 'View'}</button>`
                    : '-'
                  }
                </td>
              </tr>
            `;
          }).join('')}
        </tbody>
      </table>
    `;

    container.innerHTML = tableHtml;

    // 添加更新日志点击事件
    container.querySelectorAll('[data-changelog-index]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const index = parseInt((e.target as HTMLElement).dataset.changelogIndex || '0');
        showChangelogModal(changelogEntries[index]);
      });
    });
  };

  // ============================================================
  // 显示更新日志模态框
  // ============================================================
  const showChangelogModal = (entry: ChangelogEntry) => {
    // 移除已存在的模态框
    const existingModal = document.querySelector('.changelog-modal');
    if (existingModal) existingModal.remove();

    const lang = document.documentElement.getAttribute('data-lang') || 'zh';

    const modalHtml = `
      <div class="changelog-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
        <div class="changelog-modal-content">
          <div class="flex items-center justify-between mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">
            <div>
              <h3 id="modal-title" class="text-xl font-bold text-gray-900 dark:text-gray-100">${entry.version}</h3>
              ${entry.date ? `<span class="text-sm text-gray-500 dark:text-gray-400">${entry.date}</span>` : ''}
            </div>
            <button type="button" class="close-modal p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors" aria-label="${lang === 'zh' ? '关闭' : 'Close'}">
              <i class="fas fa-times text-lg"></i>
            </button>
          </div>
          <div class="changelog-body">
            ${entry.content}
          </div>
        </div>
      </div>
    `;

    document.body.insertAdjacentHTML('beforeend', modalHtml);

    const modal = document.querySelector('.changelog-modal') as HTMLElement;
    const closeBtn = modal.querySelector('.close-modal');

    // 显示动画
    requestAnimationFrame(() => {
      modal.classList.add('is-visible');
    });

    // 关闭函数
    const closeModal = () => {
      modal.classList.remove('is-visible');
      setTimeout(() => modal.remove(), 250);
    };

    // 绑定关闭事件
    closeBtn?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // ESC 键关闭
    const handleEsc = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        closeModal();
        document.removeEventListener('keydown', handleEsc);
      }
    };
    document.addEventListener('keydown', handleEsc);

    // 阻止滚动
    document.body.style.overflow = 'hidden';
    const observer = new MutationObserver(() => {
      if (!document.querySelector('.changelog-modal')) {
        document.body.style.overflow = '';
        observer.disconnect();
      }
    });
    observer.observe(document.body, { childList: true });
  };

  // ============================================================
  // 版本切换按钮事件
  // ============================================================
  const initVersionToggle = () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.version-toggle-btn');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.versionType as 'release' | 'pre_release';

        // 如果点击的是当前激活的按钮，则取消选择
        if (currentFilter === type) {
          currentFilter = null;
          btn.dataset.active = 'false';
          document.getElementById('versionTableSection')?.classList.add('hidden');
          return;
        }

        // 更新按钮状态
        buttons.forEach(b => b.dataset.active = 'false');
        btn.dataset.active = 'true';
        currentFilter = type;

        // 渲染表格
        renderVersionTable(type);
      });
    });
  };

  // ============================================================
  // 从 Markdown 提取 FAQ 内容
  // ============================================================
  const initFaqContent = () => {
    const source = document.getElementById('markdownSource');
    if (!source) return;

    const lang = document.documentElement.getAttribute('data-lang') || 'zh';
    const langContainer = source.querySelector(`[data-lang="${lang}"]`);
    if (!langContainer) return;

    const allElements = Array.from(langContainer.children);
    const sections: Record<string, HTMLElement[]> = {};
    let currentSection = '';

    allElements.forEach(el => {
      if (el.tagName === 'H2') {
        currentSection = (el as HTMLElement).textContent?.trim() || '';
        sections[currentSection] = [];
      } else if (currentSection) {
        sections[currentSection].push(el as HTMLElement);
      }
    });

    // FAQ
    const faqContent = document.getElementById('faqContent');
    if (faqContent) {
      const faqKey = Object.keys(sections).find(k => k.includes('常见问题') || k.includes('FAQ'));
      if (faqKey) {
        faqContent.innerHTML = sections[faqKey].map(el => el.outerHTML).join('');
      }
    }
  };

  // ============================================================
  // 初始化
  // ============================================================
  document.addEventListener('DOMContentLoaded', () => {
    // 加载版本数据
    const versionsDataEl = document.getElementById('versionsData');
    if (versionsDataEl) {
      try {
        versionsData = JSON.parse(versionsDataEl.textContent || '[]');
      } catch (e) {
        console.error('Failed to parse versions data:', e);
      }
    }

    // 解析更新日志
    parseChangelogFromMarkdown();

    // 初始化
    initFileSizes();
    initVersionToggle();
    initFaqContent();
  });

  // 监听语言变化
  window.addEventListener('language-change', () => {
    parseChangelogFromMarkdown();
    initFaqContent();

    // 如果有激活的筛选，重新渲染表格
    if (currentFilter) {
      renderVersionTable(currentFilter);
    }
  });
</script>
