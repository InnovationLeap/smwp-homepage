    border-radius: 0.375rem;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  #dynamicVersionTable .table-btn-primary {
    background: #3b82f6;
    color: white;
    border-color: #3b82f6;
  }

  #dynamicVersionTable .table-btn-primary:hover {
    background: #2563eb;
    border-color: #2563eb;
  }

  html.dark #dynamicVersionTable .table-btn-primary {
    background: #3b82f6;
    color: white;
    border-color: #3b82f6;
  }

  html.dark #dynamicVersionTable .table-btn-primary:hover {
    background: #2563eb;
    border-color: #2563eb;
  }

  #dynamicVersionTable .table-btn-secondary {
    background: #f3f4f6;
    color: #374151;
    border-color: #e5e7eb;
  }

  #dynamicVersionTable .table-btn-secondary:hover {
    background: #e5e7eb;
    border-color: #d1d5db;
  }

  html.dark #dynamicVersionTable .table-btn-secondary {
    background: #374151;
    color: #d1d5db;
    border-color: #4b5563;
  }

  html.dark #dynamicVersionTable .table-btn-secondary:hover {
    background: #4b5563;
    border-color: #6b7280;
  }

  #dynamicVersionTable .table-btn-success {
    background: #22c55e;
    color: white;
    border-color: #22c55e;
  }

  #dynamicVersionTable .table-btn-success:hover {
    background: #16a34a;
    border-color: #16a34a;
  }

  html.dark #dynamicVersionTable .table-btn-success {
    background: #22c55e;
    color: white;
    border-color: #22c55e;
  }

  html.dark #dynamicVersionTable .table-btn-success:hover {
    background: #16a34a;
    border-color: #16a34a;
  }

  /* ============================================================
     更新日志弹框样式（全局，因为弹框插入到 body）
     ============================================================ */
  .changelog-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .changelog-modal.is-visible {
    opacity: 1;
    visibility: visible;
  }

  .changelog-modal-content {
    background: white;
    border-radius: 1rem;
    width: 100%;
    max-width: 52rem;
    max-height: 85vh;
    overflow-y: auto;
    padding: 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35);
    transform: scale(0.95);
    transition: transform 0.25s ease;
  }

  .changelog-modal.is-visible .changelog-modal-content {
    transform: scale(1);
  }

  html.dark .changelog-modal-content {
    background: #1f2937;
  }

  .changelog-modal-content h4 {
    font-size: 1rem;
    font-weight: 600;
    color: #374151;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  html.dark .changelog-modal-content h4 {
    color: #d1d5db;
  }

  .changelog-modal-content ul,
  .changelog-modal-content ol {
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
    padding-left: 1.25rem;
  }

  .changelog-modal-content ul {
    list-style-type: disc;
    list-style-position: outside;
  }

  .changelog-modal-content ol {
    list-style-type: decimal;
    list-style-position: outside;
  }

  .changelog-modal-content li {
    margin-top: 0.125rem;
    margin-bottom: 0.125rem;
    line-height: 1.5;
    font-size: 0.875rem;
    color: #4b5563;
    display: list-item;
  }

  html.dark .changelog-modal-content li {
    color: #9ca3af;
  }

  /* ============================================================
     响应式调整
     ============================================================ */
  @media (max-width: 640px) {
    .download-hero {
      padding: 1.5rem;
    }

    .download-hero h1 {
      font-size: 1.75rem;
    }

    .download-btn {
      padding: 1.25rem;
    }

    .download-btn-icon {
      width: 2.5rem;
      height: 2.5rem;
    }

    .download-btn-icon i {
