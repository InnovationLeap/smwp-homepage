---
import { getEntry, render } from 'astro:content';
import { readFileSync } from 'fs';
import { join } from 'path';
import * as yaml from 'js-yaml';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const entryZh = await getEntry('zh', 'downloads');
const entryEn = await getEntry('en', 'downloads');

if (!entryZh || !entryEn) {
  throw new Error('Downloads page not found');
}

const { Content: ContentZh } = await render(entryZh);
const { Content: ContentEn } = await render(entryEn);

// ============================================================
// 从 YAML 动态读取版本信息
// ============================================================
interface VersionData {
  version: string;
  date: string;
  zipName: string;
  verCode?: number;
  type: 'release' | 'pre_release';
}

const yamlPath = join(process.cwd(), 'src/data/smwp-versions.yaml');
const yamlContent = readFileSync(yamlPath, 'utf-8');
const yamlData = yaml.load(yamlContent) as {
  release?: Array<{ [key: string]: Array<{ date?: string; zip_name?: string; ver_code?: number }> }>;
  pre_release?: Array<{ [key: string]: Array<{ date?: string; zip_name?: string; ver_code?: number }> }>;
};

// 解析版本信息
const parseVersionEntry = (item: { [key: string]: Array<{ date?: string; zip_name?: string; ver_code?: number }> }, type: 'release' | 'pre_release'): VersionData | null => {
  const versionKey = Object.keys(item)[0];
  const dataArray = item[versionKey];
  if (!dataArray) return null;

  let date = '';
  let zipName = '';
  let verCode: number | undefined;

  dataArray.forEach((dataItem: any) => {
    if (dataItem.date) date = dataItem.date;
    if (dataItem.zip_name) zipName = dataItem.zip_name;
    if (dataItem.ver_code) verCode = dataItem.ver_code;
  });

  return { version: versionKey, date, zipName, verCode, type };
};

// 按日期排序
const sortByDate = (a: VersionData, b: VersionData): number => {
  const dateA = a.date ? new Date(a.date).getTime() : 0;
  const dateB = b.date ? new Date(b.date).getTime() : 0;
  return dateB - dateA;
};

// 获取所有版本
const releases: VersionData[] = (yamlData.release || []).map(item => parseVersionEntry(item, 'release')).filter(Boolean) as VersionData[];
const preReleases: VersionData[] = (yamlData.pre_release || []).map(item => parseVersionEntry(item, 'pre_release')).filter(Boolean) as VersionData[];

releases.sort(sortByDate);
preReleases.sort(sortByDate);

// 合并所有版本用于客户端渲染
const allVersions = [...releases, ...preReleases];

const latestRelease = releases[0];
const latestPreRelease = preReleases[0];

// 构建下载链接
const DOWNLOAD_BASE = 'https://file.marioforever.net/smwp';
const latestReleaseUrl = latestRelease ? `${DOWNLOAD_BASE}/${latestRelease.zipName}` : '';
const latestPreReleaseUrl = latestPreRelease ? `${DOWNLOAD_BASE}/${latestPreRelease.zipName}` : '';
const DATA_PACKET_URL = `${DOWNLOAD_BASE}/Data.7z`;

// 将版本数据传递给客户端
const versionsJson = JSON.stringify(allVersions.map(v => ({
  version: v.version,
  date: v.date,
  zipName: v.zipName,
  verCode: v.verCode,
  type: v.type,
  downloadUrl: `${DOWNLOAD_BASE}/${v.zipName}`
})));
---

<BaseLayout titleZh={entryZh.data.title} titleEn={entryEn.data.title} descriptionZh={entryZh.data.description} descriptionEn={entryEn.data.description}>
  <Navbar />

  <main class="pt-24 sm:pt-28 pb-12 flex-1 bg-gray-50 dark:bg-gray-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Hero 下载区域 */}
      <section class="download-hero rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900 px-6 py-10 sm:px-10 sm:py-12 shadow-md mb-8 animate-fade-in">
        <div class="text-center mb-8">
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-6">
            <span data-lang="zh">下载 SMWP</span>
            <span data-lang="en">Download SMWP</span>
          </h1>
          <p class="text-gray-600 dark:text-gray-400">
            <span data-lang="zh">最新版本：</span>
            <span data-lang="en">Latest version: </span>
            {latestRelease && (
              <span class="font-semibold text-[#006eff] dark:text-[#30acff]">{latestRelease.version}</span>
            )}
            {latestRelease?.date && (
              <span class="text-gray-500 dark:text-gray-500 ml-2">({latestRelease.date})</span>
            )}
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
          {/* 程序本体下载按钮 */}
          {latestRelease && (
            <a
              href={latestReleaseUrl}
              class="download-btn group relative flex flex-col items-center justify-center p-6 bg-blue-50 dark:bg-blue-900/10 rounded-2xl border-2 border-blue-500/50 dark:border-blue-400/50 shadow-sm hover:shadow-lg hover:border-blue-500 dark:hover:border-blue-400 hover:scale-[1.02]"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="download-btn-icon w-14 h-14 flex items-center justify-center rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 mb-4 group-hover:scale-110 transition-transform duration-300">
                <i class="fas fa-download text-2xl"></i>
              </div>
              <div class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-1">
                <span data-lang="zh">程序本体</span>
                <span data-lang="en">Program</span>
              </div>
              <div class="file-size text-sm text-gray-500 dark:text-gray-500 opacity-0 transition-opacity duration-300" data-file-url={latestReleaseUrl}></div>
            </a>
          )}

          {/* 数据包下载按钮 */}
          <a
            href={DATA_PACKET_URL}
            class="download-btn group relative flex flex-col items-center justify-center p-6 bg-emerald-50 dark:bg-emerald-900/10 rounded-2xl border-2 border-emerald-500/50 dark:border-emerald-400/50 shadow-sm hover:shadow-lg hover:border-emerald-500 dark:hover:border-emerald-400 hover:scale-[1.02]"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="download-btn-icon w-14 h-14 flex items-center justify-center rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 mb-4 group-hover:scale-110 transition-transform duration-300">
              <i class="fas fa-database text-2xl"></i>
            </div>
            <div class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-1">
              <span data-lang="zh">数据包</span>
              <span data-lang="en">Music Data</span>
            </div>
            <div class="file-size text-sm text-gray-500 dark:text-gray-500 opacity-0 transition-opacity duration-300" data-file-url={DATA_PACKET_URL}></div>
          </a>
        </div>

        {/* 测试版下载 */}
        {latestPreRelease && (
          <div class="mt-8 text-center animate-slide-up" style="animation-delay: 0.1s;">
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
              <span data-lang="zh">需要测试版？</span>
              <span data-lang="en">Need pre-release?</span>
            </p>
            <a
              href={latestPreReleaseUrl}
              class="download-btn inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-amber-700 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/20 rounded-lg border border-amber-200 dark:border-amber-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:scale-[1.02] hover:border-amber-300 dark:hover:border-amber-700 transition-all duration-300 ease-in-out"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fas fa-flask"></i>
              <span>{latestPreRelease.version}</span>
              {latestPreRelease.date && (
                <span class="text-xs text-gray-500 dark:text-gray-500">({latestPreRelease.date})</span>
              )}
            </a>
          </div>
        )}

        {/* 其他下载渠道（仅中文版） */}
        <div data-lang="zh" class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 text-center">其他下载渠道</p>
          <div class="flex flex-wrap justify-center gap-x-4 gap-y-2">
            <a
              href="https://inleap.lanzouw.com/b08rcm1of"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors underline underline-offset-2 decoration-gray-300 dark:decoration-gray-600 hover:decoration-blue-500"
              target="_blank"
              rel="noopener noreferrer"
            >
              蓝奏云 (最新版本)
            </a>
            <span class="hidden sm:inline text-gray-300 dark:text-gray-600">|</span>
            <a
              href="https://inleap.lanzouw.com/b0ygccuj"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors underline underline-offset-2 decoration-gray-300 dark:decoration-gray-600 hover:decoration-blue-500"
              target="_blank"
              rel="noopener noreferrer"
            >
              蓝奏云 (旧版本)
            </a>
            <span class="hidden sm:inline text-gray-300 dark:text-gray-600">|</span>
            <a
              href="https://inleap.lanzouw.com/b0yf4d3e"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors underline underline-offset-2 decoration-gray-300 dark:decoration-gray-600 hover:decoration-blue-500"
              target="_blank"
              rel="noopener noreferrer"
            >
              蓝奏云 (测试版)
            </a>
            <span class="hidden sm:inline text-gray-300 dark:text-gray-600">|</span>
            <a
              href="https://pan.baidu.com/s/1o8yn5Js"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors underline underline-offset-2 decoration-gray-300 dark:decoration-gray-600 hover:decoration-blue-500"
              target="_blank"
              rel="noopener noreferrer"
            >
              百度网盘
            </a>
            <span class="hidden sm:inline text-gray-300 dark:text-gray-600">|</span>
            <a
              href="https://1812011858.share.123pan.cn/123pan/U3vrVv-INKf?pwd=SMWP"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors underline underline-offset-2 decoration-gray-300 dark:decoration-gray-600 hover:decoration-blue-500"
              target="_blank"
              rel="noopener noreferrer"
            >
              123 云盘 (提取码：SMWP)
            </a>
          </div>
        </div>
      </section>

      {/* 版本切换按钮区域 */}
      <section class="version-toggle-section mb-6 animate-fade-in" style="animation-delay: 0.1s;">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {/* 全部正式版按钮 */}
          <button
            type="button"
            class="version-toggle-btn group flex flex-col items-center justify-center px-6 py-8 text-base rounded-2xl border-2 transition-all duration-300"
            data-version-type="release"
            data-active="false"
          >
            <div class="flex items-center gap-2 mb-3">
              <div class="w-10 h-10 flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 group-hover:scale-110 transition-transform">
                <i class="fas fa-box text-xl"></i>
              </div>
              <span class="text-xl font-bold" data-lang="zh">全部正式版</span>
              <span class="text-xl font-bold" data-lang="en">All Releases</span>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 text-center">
              <span data-lang="zh">需要下载 SMWP 的其他正式版本？点击查看正式版本详情。</span>
              <span data-lang="en">View all stable release versions</span>
            </p>
          </button>

          {/* 全部测试版按钮 */}
          <button
            type="button"
            class="version-toggle-btn group flex flex-col items-center justify-center px-6 py-8 text-base rounded-2xl border-2 transition-all duration-300"
            data-version-type="pre_release"
            data-active="false"
          >
            <div class="flex items-center gap-2 mb-3">
              <div class="w-10 h-10 flex items-center justify-center rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400 group-hover:scale-110 transition-transform">
                <i class="fas fa-flask text-xl"></i>
              </div>
              <span class="text-xl font-bold" data-lang="zh">全部测试版</span>
              <span class="text-xl font-bold" data-lang="en">All Pre-releases</span>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 text-center">
              <span data-lang="zh">需要下载 SMWP 的测试版本？点击查看全部测试版本详情。</span>
              <span data-lang="en">View all pre-release versions</span>
            </p>
          </button>
        </div>
      </section>

      {/* 动态版本表格区域 */}
      <section id="versionTableSection" class="hidden mb-6 animate-fade-in">
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900 shadow-md overflow-hidden">
          <div class="px-4 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
            <h2 id="versionTableTitle" class="text-lg font-semibold text-gray-900 dark:text-gray-100">
              <span data-lang="zh">版本列表</span>
              <span data-lang="en">Version List</span>
            </h2>
          </div>
          <div id="dynamicVersionTable" class="overflow-x-auto"></div>
        </div>
      </section>

      {/* 信息面板区域 */}
      <article class="content-card prose max-w-none rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900 px-5 py-7 sm:px-9 sm:py-9 shadow-md prose-headings:text-gray-900 prose-p:text-gray-600 dark:prose-invert dark:prose-headings:text-gray-100 dark:prose-p:text-gray-300 animate-fade-in" style="animation-delay: 0.15s;">

        {/* 用户须知 */}
        <details class="info-panel mb-6 border border-blue-200 dark:border-blue-800/50 rounded-xl overflow-hidden group" open>
          <summary class="info-summary cursor-pointer bg-blue-50 dark:bg-blue-900/15 px-5 py-3.5 font-bold text-blue-800 dark:text-blue-300 hover:bg-blue-100 dark:hover:bg-blue-900/25 transition-colors flex items-center justify-between">
            <div class="flex items-center gap-2 text-lg">
              <i class="fas fa-info-circle text-blue-500 dark:text-blue-400"></i>
              <span data-lang="zh">用户须知</span>
              <span data-lang="en">User Guide</span>
            </div>
            <svg class="info-chevron w-5 h-5 text-blue-400 dark:text-blue-500 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="info-content px-6 py-4 bg-white dark:bg-gray-900 prose-sm border-t border-blue-100 dark:border-blue-800/30">
            <div data-lang="zh">
              <h3>运行程序前</h3>
              <ol>
                <li>Windows 7 用户，请下载 <a href="https://file.marioforever.net/smwp/dotNetFx40_Full_x86_x64.exe" target="_blank" rel="noopener noreferrer">dotNetFx40_Full_x86_x64.exe</a> 以安装 .NET Framework 4。Windows 8/8.1/10/11 系统自带高版本的 .NET Framework，无需额外操作。</li>
                <li>下载音乐包 <a href={DATA_PACKET_URL} target="_blank" rel="noopener noreferrer">Data.7z</a>，将其解压缩并把其中的 <code>Data</code> 文件夹存放至 SMWP 主程序所在的目录。</li>
              </ol>
              <h3>其他说明</h3>
              <ol class="mb-0">
                <li>这一系列的更新都基于 Mario Worker 4.1 版本。</li>
                <li>SMWP 的默认保存格式为 .smwl，该格式不兼容 Mario Worker 4.4 与一期版本的 SMWP。使用此版本的 SMWP 可以读取 .mfl 格式的关卡，但无法保存为 .mfl 格式。</li>
              </ol>
            </div>
            <div data-lang="en">
              <h3>Before running the program</h3>
              <ol>
                <li>Make sure .NET Framework 4.0 or newer is installed on your system. If you're using Windows 7, you will need to manually download and install it. Windows 8 and newer already include newer versions of .NET Framework by default, so no additional action is required.</li>
                <li>Download <a href={DATA_PACKET_URL} target="_blank" rel="noopener noreferrer">Data.7z</a>, extract it, and place the <code>Data</code> folder into the same directory as the SMWP executable (for example, <code>SuperMarioWorkerProject_v1.x.x.exe</code>). If you already have the Data folder, please ensure it is located in the same directory as the SMWP executable.</li>
              </ol>
              <h3>Additional Notes</h3>
              <ol class="mb-0">
                <li>All current updates of Super Mario Worker Project v1.x are based on Mario Worker 1.1.</li>
                <li>SMWP saves levels in the <code>.smwl</code> format by default. This format is not compatible with Mario Worker 1.1 or SMWP v0.x. <br>
                    Levels saved in this format can be loaded by the current or any newer version of SMWP v1.x. However, if you try to load them with an older version of SMWP v1.x, a warning will appear, and some level elements may be lost. <br>
                    You can also open <code>.mfl</code> levels created in Mario Worker 1.1, but SMWP cannot save levels in the <code>.mfl</code> format.
                </li>
                <li>SMWP is still under active development. If you encounter any issues, please contact INNOVATION LEAP.</li>
              </ol>
            </div>
          </div>
        </details>

        {/* 常见问题 */}
        <details class="info-panel border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden group" open>
          <summary class="info-summary cursor-pointer bg-gray-50 dark:bg-gray-800/50 px-5 py-3.5 font-bold text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors flex items-center justify-between">
            <div class="flex items-center gap-2 text-lg">
              <i class="fas fa-question-circle text-gray-500 dark:text-gray-400"></i>
              <span data-lang="zh">常见问题</span>
              <span data-lang="en">FAQ</span>
            </div>
            <svg class="info-chevron w-5 h-5 text-gray-400 dark:text-gray-500 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="info-content px-6 py-4 bg-white dark:bg-gray-900 prose-sm border-t border-gray-100 dark:border-gray-800" id="faqContent"></div>
        </details>

        {/* 隐藏的 Markdown 内容源 */}
        <div id="markdownSource" class="hidden">
          <div data-lang="zh">
            <ContentZh />
          </div>
          <div data-lang="en">
            <ContentEn />
          </div>
        </div>

        {/* 版本数据 */}
        <script type="application/json" id="versionsData" set:html={versionsJson} />
      </article>
    </div>
  </main>

  <Footer marginTop="mt-16" />
</BaseLayout>

<style is:global>
  /* ============================================================
     动画定义
     ============================================================ */
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.4s ease-out forwards;
  }

  .animate-slide-up {
    animation: slide-up 0.3s ease-out forwards;
  }

  /* ============================================================
     下载按钮样式
     ============================================================ */
  .download-btn {
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .download-btn .file-size:not(:empty) {
    opacity: 1;
  }

  /* ============================================================
     信息面板样式
     ============================================================ */
  .info-panel summary {
    list-style: none;
  }

  .info-panel summary::-webkit-details-marker {
    display: none;
  }

  .info-content h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 0.75rem;
    margin-bottom: 0.375rem;
    color: #374151;
  }

  html.dark .info-content h3 {
    color: #d1d5db;
  }

  .info-content ol,
  .info-content ul {
    margin-top: 0.375rem;
    margin-bottom: 0.375rem;
    padding-left: 1.25rem;
  }

  .info-content li {
    margin-top: 0.125rem;
    margin-bottom: 0.125rem;
  }

  .info-content p {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* ============================================================
     更新日志样式（已移除独立展示，保留用于表格内显示）
     ============================================================ */

  /* ============================================================
     版本切换按钮样式
     ============================================================ */
  .version-toggle-btn {
    border-color: #e5e7eb;
    background: white;
    color: #374151;
    cursor: pointer;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  .version-toggle-btn:hover:not([data-active="true"]) {
    background: #f9fafb;
    border-color: #3b82f6;
    transform: translateY(-2px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .version-toggle-btn[data-active="true"] {
    border-color: #3b82f6;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    color: #1e40af;
    box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.2);
  }

  html.dark .version-toggle-btn {
    border-color: #374151;
    background: #111827;
    color: #d1d5db;
  }

  html.dark .version-toggle-btn:hover:not([data-active="true"]) {
    background: #1f2937;
    border-color: #3b82f6;
  }

  html.dark .version-toggle-btn[data-active="true"] {
    border-color: #3b82f6;
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
    color: #eff6ff;
  }

  /* ============================================================
     动态版本表格样式
     ============================================================ */
  #dynamicVersionTable table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  #dynamicVersionTable thead {
    background: #f9fafb;
  }

  html.dark #dynamicVersionTable thead {
    background: #1f2937;
  }

  #dynamicVersionTable th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #374151;
    border-bottom: 1px solid #e5e7eb;
    white-space: nowrap;
    vertical-align: middle;
  }

