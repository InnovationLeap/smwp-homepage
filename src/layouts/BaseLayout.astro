---
interface Props {
  titleZh: string;
  titleEn: string;
  descriptionZh?: string;
  descriptionEn?: string;
}

const { titleZh, titleEn, descriptionZh, descriptionEn } = Astro.props;

const SITE_NAME = 'Super Mario Worker Project';
const TITLE_SUFFIX = ` | ${SITE_NAME}`;
const fullTitleZh = titleZh === SITE_NAME ? titleZh : `${titleZh}${TITLE_SUFFIX}`;
// English title is handled client-side in the <script> block
const _fullTitleEn = titleEn === SITE_NAME ? titleEn : `${titleEn}${TITLE_SUFFIX}`;

import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN" data-title-zh={titleZh} data-title-en={titleEn} data-desc-zh={descriptionZh} data-desc-en={descriptionEn}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={descriptionZh} />
    <link rel="icon" type="image/png" href="/images/mworker.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      (() => {
        const docEl = document.documentElement;

        // Theme
        const savedTheme = localStorage.getItem('theme');
        const isDark = savedTheme ? savedTheme === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        docEl.classList.toggle('dark', isDark);

        // Language
        const savedLang = localStorage.getItem('lang') || (navigator.language.startsWith('zh') ? 'zh' : 'en');
        docEl.setAttribute('data-lang', savedLang);
        docEl.setAttribute('lang', savedLang === 'zh' ? 'zh-CN' : 'en');

        // Immediate Title/Description update to prevent flash
        const title = savedLang === 'en' ? docEl.getAttribute('data-title-en') : docEl.getAttribute('data-title-zh');
        if (title) {
          const siteName = 'Super Mario Worker Project';
          document.title = title === siteName ? title : `${title} | ${siteName}`;
        }
        const desc = savedLang === 'en' ? docEl.getAttribute('data-desc-en') : docEl.getAttribute('data-desc-zh');
        if (desc) {
          const metaDesc = document.querySelector('meta[name="description"]');
          if (metaDesc) metaDesc.setAttribute('content', desc);
        }
      })();
    </script>
    <title>{fullTitleZh}</title>
  </head>
  <body class="min-h-screen font-sans flex flex-col">
    <slot />

    <!-- Back to Top Button -->
    <button
      id="back-to-top"
      aria-label="Back to top"
      class="fixed bottom-6 right-6 z-50 w-10 h-10 flex items-center justify-center
             rounded-full bg-white dark:bg-gray-800 text-[#008cff] shadow-lg
             transition-all duration-300 ease-out
             opacity-0 pointer-events-none
             hover:bg-[#008cff] hover:text-white
             dark:hover:bg-[#4da3ff] dark:hover:text-white
             focus:outline-none focus-visible:ring-2 focus-visible:ring-[#008cff] focus-visible:ring-offset-2
             dark:focus-visible:ring-offset-gray-900"
    >
      <i class="fas fa-arrow-up text-lg"></i>
    </button>
  </body>
</html>

<script>
  const getDefaultLang = () => navigator.language.startsWith('zh') ? 'zh' : 'en';

  const SITE_NAME = 'Super Mario Worker Project';

  const updatePageTitleAndDesc = (lang: string) => {
    const root = document.documentElement;
    const titleZh = root.getAttribute('data-title-zh');
    const titleEn = root.getAttribute('data-title-en');
    const descZh = root.getAttribute('data-desc-zh');
    const descEn = root.getAttribute('data-desc-en');

    if (lang === 'en') {
      if (titleEn) document.title = titleEn === SITE_NAME ? titleEn : `${titleEn} | ${SITE_NAME}`;
      const metaDesc = document.querySelector('meta[name="description"]');
      if (metaDesc && descEn) metaDesc.setAttribute('content', descEn);
    } else {
      if (titleZh) document.title = titleZh === SITE_NAME ? titleZh : `${titleZh} | ${SITE_NAME}`;
      const metaDesc = document.querySelector('meta[name="description"]');
      if (metaDesc && descZh) metaDesc.setAttribute('content', descZh);
    }
  };

  const savedLang = localStorage.getItem('lang') || getDefaultLang();
  updatePageTitleAndDesc(savedLang);

  window.addEventListener('language-change', ((e: CustomEvent) => {
    updatePageTitleAndDesc(e.detail.lang);
  }) as EventListener);

  document.addEventListener('astro:page-load', () => {
    const currentLang = localStorage.getItem('lang') || getDefaultLang();
    updatePageTitleAndDesc(currentLang);
  });

  /* Mark external text links with .ext-link class */
  const markExternalLinks = () => {
    document.querySelectorAll('a[href^="http"]').forEach((a) => {
      const href = a.getAttribute('href');
      if (!href) return;

      /* Skip navbar links */
      if (a.closest('.site-header')) return;

      /* Skip button-styled links */
      const cls = a.className;
      if (/\brounded-full\b/.test(cls) || /!text-white/.test(cls) || /\bbg-gradient\b/.test(cls)) return;

      /* Skip icon-only links (contain <i> or <svg> but no text content) */
      const hasIcon = a.querySelector('i, svg');
      const hasText = Array.from(a.childNodes).some(
        (n) => n.nodeType === Node.TEXT_NODE && n.textContent?.trim()
      );
      if (hasIcon && !hasText) return;

      try {
        const url = new URL(href);
        if (!url.hostname.endsWith('marioforever.net')) {
          a.classList.add('ext-link');
        }
      } catch {
        /* invalid URL, skip */
      }
    });
  };

  markExternalLinks();
  document.addEventListener('astro:page-load', markExternalLinks);

  /* Back to Top Button */
  const backToTopBtn = document.getElementById('back-to-top');

  if (backToTopBtn) {
    const toggleBackToTop = () => {
      if (window.scrollY > 300) {
        backToTopBtn.classList.remove('opacity-0', 'pointer-events-none', 'scale-90');
        backToTopBtn.classList.add('opacity-100', 'pointer-events-auto', 'scale-100');
      } else {
        backToTopBtn.classList.remove('opacity-100', 'pointer-events-auto', 'scale-100');
        backToTopBtn.classList.add('opacity-0', 'pointer-events-none', 'scale-90');
      }
    };

    window.addEventListener('scroll', toggleBackToTop, { passive: true });

    backToTopBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    /* Check initial scroll position */
    toggleBackToTop();

    /* Re-check after Astro page transitions */
    document.addEventListener('astro:page-load', toggleBackToTop);
  }
</script>
